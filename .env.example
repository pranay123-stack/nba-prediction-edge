# === Strategy Tuning ===
MIN_EDGE_THRESHOLD=0.03
MOMENTUM_LAG_WINDOW_MS=30000
INJURY_POLL_INTERVAL_MS=15000
SIGNAL_COOLDOWN_MS=60000
